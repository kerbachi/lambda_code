        },
        {
            "Effect": "Deny",
            "Action": [
                "cloudformation:CreateChangeSet",
                "cloudformation:CreateStack",
                "cloudformation:Delete*",
                "cloudformation:Set*",
                "cloudformation:Update*"
            ],
            "Resource": [
                "arn:aws:cloudformation:*:*:stack/agt*",
                "arn:aws:cloudformation:*:*:stack/AGT*"
            ]
        },
        {
            "Effect": "Deny",
            "Action": [
                "aoss:CreateSecurityPolicy",
                "aoss:UpdateSecurityPolicy",
                "ec2:a*Vpc*",
                "ec2:c*Vpc*",
                "ec2:deletevpc*",
                "ec2:Dis*VpcCidrBlock",
                "ec2:m*Vpc*",
                "ec2:*Vpn*",
                "ec2:AllocateAddress",
                "ec2:AllocateIpam*",
                "ec2:AssignIpv6*",
                "ec2:AssociateAddress",
                "ec2:AssociateRouteTable",
                "ec2:AssociateSubnetCidrBlock",
                "ec2:Attach*Gateway",
                "ec2:*Bundle*",
                "ec2:CancelConversionTask",
                "ec2:CancelExportTask",
                "ec2:CancelImportTask",
                "ec2:CancelReservedInstancesL*",
                "ec2:Copy*Image",
                "ec2:Create*Gatewa*",
                "ec2:CreateDefault*",
                "ec2:CreateDhcp*",
                "ec2:CreateFlowLogs",
                "ec2:Create*Image",
                "ec2:Create*ExportTask",
                "ec2:*Acl",
                "ec2:*AclE*",
                "ec2:*AclA*",
                "ec2:CreateReserved*",
                "ec2:CreateRoute*",
                "ec2:CreateSubnet",
                "ec2:De*Gateway",
                "ec2:DeleteDhcp*",
                "ec2:DeleteFlowLogs",
                "ec2:*Fpga*",
                "ec2:DeleteRoute*",
                "ec2:DeleteSubnet",
                "ec2:Disable*",
                "ec2:DisassociateRouteTable",
                "ec2:Dis*SubnetCidrBlock",
                "ec2:EnableVgw*",
                "ec2:EnableVpc*",
                "ec2:GetHost*",
                "ec2:GetPasswordData",
                "ec2:GetReservedIns*",
                "ec2:ImportImage",
                "ec2:ImportInstance",
                "ec2:Modify*Format",
                "ec2:Modify*Credit*",
                "ec2:ModifyReserved*",
                "ec2:ModifySubnetAttribute",
                "ec2:Purchase*",
                "ec2:RegisterImage",
                "ec2:ReplaceRoute*",
                "ec2:RestoreAddress*",
                "ec2:UnassignIpv6*",
                "ecr-public:Create*",
                "ecr-public:*Delete*",
                "ecr-public:*LayerU*",
                "ecr-public:Put*",
                "ecr-public:Up*",
                "iam:AttachUserP*",
                "iam:CreateAccount*",
                "iam:CreateLogin*",
                "iam:CreateSAML*",
                "iam:CreateUser",
                "iam:CreateVirtualMFA*",
                "iam:EnableMFA*",
                "iam:DeleteAccount*",
                "iam:Delete*Boundary",
                "iam:DeleteSAML*",
                "iam:PutUserP*",
                "iam:UpdateAccount*",
                "iam:UpdateSAML*",
                "iam:AddUserToGroup",
                "iam:AttachGroupPolicy",
                "iam:PutGroupPolicy"
            ],
            "Resource": "*"
        },
        {
            "Effect": "Deny",
            "Action": [
                "iam:AttachRolePolicy",
                "iam:DetachRolePolicy",
                "iam:PutRolePolicy",
                "iam:CreatePolicyVersion",
                "iam:Delete*",
                "iam:Update*",
                "iam:SetDefaultPolicyVersion"
            ],
            "Resource": [
                "arn:aws:iam::${account_number}:policy/UENTAWS*",
                "arn:aws:iam::${account_number}:policy/AGT*",
                "arn:aws:iam::${account_number}:role/UENTAWS*"
            ]
        },
        {
            "Effect": "Deny",
            "Action": [
                "iam:AttachRolePolicy",
                "iam:DetachRolePolicy",
                "iam:PutRolePolicy"
            ],
            "Resource": "*",
            "Condition": {
                "StringNotLike": {
                    "iam:PermissionsBoundary": "arn:aws:iam::${account_number}:policy/AGT-IAM-BOUNDARY*"
                }
            }
        },
        {
            "Effect": "Deny",
            "Action": [
                "iam:CreateRole",
                "iam:Put*Boundary"
            ],
            "Resource": "*",
            "Condition": {
                "StringNotEquals": {
                    "iam:PermissionsBoundary": [
                        "arn:aws:iam::${account_number}:policy/AGT-IAM-BOUNDARY-BASE",
                        "arn:aws:iam::${account_number}:policy/AGT-IAM-BOUNDARY-CUSTOM-RAM"
                    ]
                }
            }
        }
    ]
}